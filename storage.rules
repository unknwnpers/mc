rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.get('role', '') in ['admin', 'superadmin'];
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*') &&
             request.resource.size < 5 * 1024 * 1024; // 5MB
    }

    function isValidUserFile() {
      return request.resource.size < 2 * 1024 * 1024; // 2MB
    }

    /**
     * SYSTEM IMAGES
     */
    match /system/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImage();
    }

    /**
     * MARKETING IMAGES
     */
    match /marketing/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImage();
    }

    /**
     * CATEGORY IMAGES
     */
    match /category/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImage();
    }

    /**
     * PRODUCT IMAGES
     */
    match /product/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImage();
    }

    /**
     * USER FILES (avatars etc)
     */
    match /users/{userId}/{allPaths=**} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow write: if isAdmin() || (
        isAuthenticated() &&
        request.auth.uid == userId &&
        isValidUserFile()
      );
    }

    /**
     * TEMP UPLOADS (strict)
     */
    match /temp/{userId}/{allPaths=**} {
      allow read: if isAdmin();

      allow write: if isAuthenticated() &&
        request.auth.uid == userId &&
        isValidImage();

      allow delete: if isAdmin() ||
        (isAuthenticated() && request.auth.uid == userId);
    }

    /**
     * DEFAULT DENY
     */
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
