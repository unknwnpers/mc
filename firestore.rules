rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // Fails safely if role property is not present in token
      return isAuthenticated() && request.auth.token.get('role', '') in ['admin', 'superadmin'];
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.get('role', '') == 'superadmin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /**
     * USERS COLLECTION
     */
    match /users/{userId} {
      // User can read their own profile, Admin can read all
      allow read: if isOwner(userId) || isAdmin();

      // Users MUST be able to create their profile through the UI (registration flow)
      allow create: if isOwner(userId);

      // User can update their own profile, but CANNOT spoof or escalate their role
      allow update: if isOwner(userId)
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);

      allow delete: if false;
    }
    
    /**
     * USER CART
     * Users can only access their own cart items
     */
    match /users/{userId}/cart/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    /**
     * USER FAVORITES
     * Users can only access their own favorites
     */
    match /users/{userId}/favorites/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    /**
     * CATEGORIES COLLECTION
     */
    match /categories/{categoryId} {
      // Public view
      allow read: if true;
      allow write: if false; // Admin tasks handled in backend using Admin SDK
    }

    /**
     * CURATED COLLECTIONS
     */
    match /curated_collections/{collectionId} {
      // Public view for active collections
      allow read: if true;
      allow write: if false; // Admin tasks handled in backend using Admin SDK
    }

    /**
     * PRODUCTS COLLECTION
     */
    match /products/{productId} {
      // Public view
      allow read: if true;
      allow write: if false; // Admin tasks handled in backend using Admin SDK
    }

    /**
     * ORDERS COLLECTION
     */
    match /orders/{orderId} {
      // Users can see their own orders, Admins can view all business orders
      allow read: if isAuthenticated() &&
        (request.auth.uid == resource.data.userId || isAdmin());

      // Clients MUST be able to initiate/construct the order locally before payment gateway
      allow create: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid;
      
      // Clients CANNOT alter order statuses or payment details after creation.
      // Payment verifications and dispatch updates are exclusively Admin SDK territory.
      allow update, delete: if false;
    }

    /**
     * INVENTORY LOGS
     */
    match /inventory_logs/{logId} {
      // Handled purely by backend systems to track edits
      allow read, write: if false;
    }

    /**
     * RESERVATIONS
     */
    match /reservations/{resId} {
      allow read: if isAuthenticated() &&
        request.auth.uid == resource.data.userId;

      allow write: if false;
    }

    /**
     * ADMIN DASHBOARD DATA
     */
    match /admin_data/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    /**
     * REVIEWS COLLECTION
     */
    match /reviews/{reviewId} {
      // Anyone can read approved reviews
      allow read: if resource.data.status == 'approved' || isAdmin();
      
      // Authenticated users can create reviews for products they purchased
      allow create: if isAuthenticated() 
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.status == 'pending';
      
      // Users can update their own pending reviews, admins can update any
      allow update: if (isAuthenticated() 
        && request.auth.uid == resource.data.userId 
        && resource.data.status == 'pending')
        || isAdmin();
      
      allow delete: if isAdmin();
    }

    /**
     * COUPONS COLLECTION
     */
    match /coupons/{couponId} {
      // Public can read active coupons (for validation)
      allow read: if resource.data.active == true || isAdmin();
      
      // All writes handled by Admin SDK
      allow write: if false;
    }

    /**
     * OFFERS COLLECTION
     */
    match /offers/{offerId} {
      // Public can read active offers
      allow read: if resource.data.isActive == true || isAdmin();
      
      // All writes handled by Admin SDK
      allow write: if false;
    }

    /**
     * LOGIN HISTORY (Security)
     */
    match /login_history/{docId} {
      // Users can read their own login history
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow write: if false; // Managed by backend
    }

    /**
     * TRUSTED DEVICES (Security)
     */
    match /trusted_devices/{docId} {
      // Users can read their own trusted devices
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow write: if false; // Managed by backend
    }

    /**
     * PASSWORD HISTORY (Security)
     */
    match /password_history/{docId} {
      allow read, write: if false; // Managed by backend only
    }

    /**
     * SECURITY LOGS (Security)
     */
    match /security_logs/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Managed by backend only
    }

    /**
     * IMAGE METADATA
     */
    match /image_metadata/{docId} {
      allow read: if true; // Public read for active images
      allow write: if isAdmin(); // Admin only
    }

    /**
     * SYSTEM SETTINGS (Flash Screen, etc.)
     */
    match /settings/{docId} {
      allow read: if true; // Public needs to read flash screen config
      allow write: if isAdmin(); // Only admins can update settings
    }
  }
}
