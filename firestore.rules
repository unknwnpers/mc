rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // Fails safely if role property is not present in token
      return isAuthenticated() && request.auth.token.get('role', '') in ['admin', 'superadmin'];
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.get('role', '') == 'superadmin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /**
     * USERS COLLECTION
     */
    match /users/{userId} {
      // User can read their own profile, Admin can read all
      allow read: if isOwner(userId) || isAdmin();

      // Users MUST be able to create their profile through the UI (registration flow)
      allow create: if isOwner(userId);

      // User can update their own profile, but CANNOT spoof or escalate their role
      allow update: if isOwner(userId)
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);

      allow delete: if false;
    }
    
    /**
     * USERS SUBCOLLECTIONS (cart, favorites)
     */
    match /users/{userId}/{subcollection}/{docId} {
      // Only the owning user can access what is in their cart/favorites
      allow read, write: if isOwner(userId);
    }

    /**
     * CATEGORIES COLLECTION
     */
    match /categories/{categoryId} {
      // Public view
      allow read: if true;
      allow write: if false; // Admin tasks handled in backend using Admin SDK
    }

    /**
     * CURATED COLLECTIONS
     */
    match /curated_collections/{collectionId} {
      // Public view for active collections
      allow read: if true;
      allow write: if false; // Admin tasks handled in backend using Admin SDK
    }

    /**
     * PRODUCTS COLLECTION
     */
    match /products/{productId} {
      // Public view
      allow read: if true;
      allow write: if false; // Admin tasks handled in backend using Admin SDK
    }

    /**
     * ORDERS COLLECTION
     */
    match /orders/{orderId} {
      // Users can see their own orders, Admins can view all business orders
      allow read: if isAuthenticated() &&
        (request.auth.uid == resource.data.userId || isAdmin());

      // Clients MUST be able to initiate/construct the order locally before payment gateway
      allow create: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid;
      
      // Clients CANNOT alter order statuses or payment details after creation.
      // Payment verifications and dispatch updates are exclusively Admin SDK territory.
      allow update, delete: if false;
    }

    /**
     * INVENTORY LOGS
     */
    match /inventory_logs/{logId} {
      // Handled purely by backend systems to track edits
      allow read, write: if false;
    }

    /**
     * RESERVATIONS
     */
    match /reservations/{resId} {
      allow read: if isAuthenticated() &&
        request.auth.uid == resource.data.userId;

      allow write: if false;
    }

    /**
     * ADMIN DASHBOARD DATA
     */
    match /admin_data/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
