# ── Firebase Admin (Server Side) ─────────────────────────────────────────────
# Get these from Firebase Console -> Project Settings -> Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBADANBgkqhkiG9w0BAQEFAASCBKYwggSiAgEAAoIBAQ..."

# ── Firebase Client (Public) ────────────────────────────────────────────────
# Get these from Firebase Console -> Project Settings -> General -> Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef...

# ── Razorpay ─────────────────────────────────────────────────────────────────
# Get these from Razorpay Dashboard -> Settings -> API Keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Get this from Razorpay Dashboard -> Settings -> Webhooks
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── App Configuration ────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Update this to your Vercel URL in production: https://your-app.vercel.app
